<!--
  Lab: Azure API Management – Secure Payments API
  Objetivo: padronizar corpo JSON e headers em falhas do pipeline (ex.: autenticação e limite de taxa),
  sem expor detalhes internos do gateway ou do backend.

  Contexto de uso:
  - Bloco <on-error> após <base />, para complementar o tratamento padrão.
  - context.LastError.Source varia conforme a política que falhou (ex.: validate-jwt); fontes de quota/rate-limit
    podem aparecer com nomes específicos da versão do serviço — valide no portal em "Trace" após um teste.
  - Para 429 explícito, pode ser necessário combinar com política de limite e inspecionar o trace.
-->
<policies>
  <inbound>
    <base />
  </inbound>
  <backend>
    <base />
  </backend>
  <outbound>
    <base />
  </outbound>
  <on-error>
    <base />
    <choose>
      <when condition="@(context.LastError.Source == &quot;validate-jwt&quot;)">
        <return-response>
          <set-status code="401" reason="Unauthorized" />
          <set-header name="Content-Type" exists-action="override">
            <value>application/json</value>
          </set-header>
          <set-body>{
  "error": "unauthorized",
  "message": "Access token validation failed.",
  "code": "PAYMENTS_AUTH_TOKEN_INVALID"
}</set-body>
        </return-response>
      </when>
      <when condition="@(context.LastError.Source == &quot;rate-limit-key&quot; || context.LastError.Source == &quot;quota&quot;)">
        <return-response>
          <set-status code="429" reason="Too Many Requests" />
          <set-header name="Content-Type" exists-action="override">
            <value>application/json</value>
          </set-header>
          <set-body>{
  "error": "too_many_requests",
  "message": "Rate limit exceeded. Retry after a backoff period.",
  "code": "PAYMENTS_RATE_LIMIT"
}</set-body>
        </return-response>
      </when>
      <otherwise>
        <return-response>
          <set-status code="500" reason="Internal Server Error" />
          <set-header name="Content-Type" exists-action="override">
            <value>application/json</value>
          </set-header>
          <set-header name="X-Correlation-Id" exists-action="override">
            <value>@(context.RequestId.ToString())</value>
          </set-header>
          <set-body>{
  "error": "gateway_error",
  "message": "A processing error occurred.",
  "code": "PAYMENTS_GATEWAY_ERROR"
}</set-body>
        </return-response>
      </otherwise>
    </choose>
  </on-error>
</policies>
